  "kurdish": [
    {
      "id": 1,
      "name": "ناوی هەرە تاک و گەورە و پیرۆزی دیار و زانراوی خودای گەورەیە"
    },
    {
      "id": 2,
      "name": "بەخشندە و میهرەبان و بەسۆز و بەزەییە لەبەرامبەر بە هەموو شتێک لە بوونەوەردا"
    },
    {
      "id": 3,
      "name": "بەخشندە و میهرەبان و بەسۆز و بەزەییە لە دواڕۆژدا بەرامبەر بە ئیمانداران و هەرشتێک خودا ڕەحمی پێ بکات"
    },
    {
      "id": 4,
      "name": "هەمیشە پاشا و دەسەڵاتدار و سەرۆک و خاوەنی هەموو شتێکە لە بوونەوەر و دونیاو دوارۆژدا"
    },
    {
      "id": 5,
      "name": "زۆر پاک و بێ گەرد و بێ کەم و کوڕی و بێ هەڵە و ناتەواوییە"
    },
    {
      "id": 6,
      "name": "زۆر ساغ و بێ گەرد و بێ عەیب و ئاشتی خواز و ئاشتی دار و ئاشتی پەروەرە"
